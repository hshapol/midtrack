// fetch-data.js
// Runs daily via GitHub Actions. Scrapes Ballotpedia, Polymarket, Kalshi, RCP.
// Writes results to data/data.json

import fetch from 'node-fetch';
import * as cheerio from 'cheerio';
import { writeFileSync, readFileSync, mkdirSync } from 'fs';

const TODAY = new Date().toISOString().split('T')[0];

// ─── HELPERS ────────────────────────────────────────────────────────────────

async function fetchHTML(url) {
  const res = await fetch(url, {
    headers: {
      'User-Agent': 'Mozilla/5.0 (compatible; MidtermTracker/1.0)',
      'Accept': 'text/html,application/xhtml+xml',
    },
    timeout: 15000,
  });
  if (!res.ok) throw new Error(`HTTP ${res.status} for ${url}`);
  return res.text();
}

async function fetchJSON(url) {
  const res = await fetch(url, {
    headers: { 'Accept': 'application/json' },
    timeout: 15000,
  });
  if (!res.ok) throw new Error(`HTTP ${res.status} for ${url}`);
  return res.json();
}

function safe(fn, fallback = null) {
  try { return fn(); } catch { return fallback; }
}

// ─── BALLOTPEDIA: Senate ratings (Cook + Sabato + IE) ───────────────────────

async function fetchBallotpediaRatings() {
  console.log('Fetching Ballotpedia senate ratings...');
  try {
    const html = await fetchHTML('https://ballotpedia.org/United_States_Senate_elections,_2026');
    const $ = cheerio.load(html);
    const ratings = {};

    // Ballotpedia has a comparison table with Cook, IE, Sabato ratings
    $('table').each((_, table) => {
      const headers = [];
      $(table).find('th').each((_, th) => headers.push($(th).text().trim().toLowerCase()));

      const hasCook = headers.some(h => h.includes('cook'));
      const hasSabato = headers.some(h => h.includes('sabato') || h.includes('crystal'));
      const hasIE = headers.some(h => h.includes('inside') || h.includes('elections'));

      if (!hasCook && !hasSabato && !hasIE) return;

      // Find column indices
      let stateCol = -1, cookCol = -1, sabatoCol = -1, ieCol = -1;
      $(table).find('tr').first().find('th, td').each((i, cell) => {
        const t = $(cell).text().trim().toLowerCase();
        if (t.includes('state') || t.includes('race')) stateCol = i;
        if (t.includes('cook')) cookCol = i;
        if (t.includes('sabato') || t.includes('crystal')) sabatoCol = i;
        if (t.includes('inside')) ieCol = i;
      });

      $(table).find('tr').slice(1).each((_, row) => {
        const cells = $(row).find('td');
        if (cells.length < 2) return;

        const state = safe(() => $(cells[stateCol >= 0 ? stateCol : 0]).text().trim());
        if (!state) return;

        // Normalize state name
        const stateName = state.replace(/\s*\(.*\)/, '').trim();

        ratings[stateName] = {
          cook:   cookCol >= 0    ? safe(() => $(cells[cookCol]).text().trim())   : null,
          sabato: sabatoCol >= 0  ? safe(() => $(cells[sabatoCol]).text().trim()) : null,
          ie:     ieCol >= 0      ? safe(() => $(cells[ieCol]).text().trim())     : null,
        };
      });
    });

    console.log(`  Got ratings for ${Object.keys(ratings).length} states`);
    return ratings;
  } catch (e) {
    console.error('  Ballotpedia error:', e.message);
    return {};
  }
}

// ─── POLYMARKET ─────────────────────────────────────────────────────────────

async function fetchPolymarket() {
  console.log('Fetching Polymarket markets...');
  const markets = {
    houseD: null, senateR: null,
    splitPct: null, dSweepPct: null, repSweepPct: null,
  };

  // Polymarket CLOB API - fetch by slug
  const slugs = [
    { key: 'house',   slug: 'which-party-will-win-the-house-in-2026' },
    { key: 'senate',  slug: 'which-party-will-win-the-senate-in-2026' },
    { key: 'balance', slug: 'balance-of-power-2026-midterms' },
  ];

  for (const { key, slug } of slugs) {
    try {
      const data = await fetchJSON(`https://gamma-api.polymarket.com/events?slug=${slug}&limit=1`);
      if (!data || !data.length) continue;
      const event = data[0];

      if (key === 'house') {
        const demMarket = event.markets?.find(m =>
          m.outcomePrices && (m.question?.toLowerCase().includes('democrat') || m.groupItemTitle?.toLowerCase().includes('democrat'))
        );
        if (demMarket?.outcomePrices) {
          const prices = JSON.parse(demMarket.outcomePrices);
          markets.houseD = Math.round(parseFloat(prices[0]) * 100);
        }
      }

      if (key === 'senate') {
        const repMarket = event.markets?.find(m =>
          m.question?.toLowerCase().includes('republican') || m.groupItemTitle?.toLowerCase().includes('republican')
        );
        if (repMarket?.outcomePrices) {
          const prices = JSON.parse(repMarket.outcomePrices);
          markets.senateR = Math.round(parseFloat(prices[0]) * 100);
        }
      }

      if (key === 'balance') {
        for (const m of (event.markets || [])) {
          const title = (m.question || m.groupItemTitle || '').toLowerCase();
          if (!m.outcomePrices) continue;
          const prices = JSON.parse(m.outcomePrices);
          const pct = Math.round(parseFloat(prices[0]) * 100);

          if (title.includes('republican') && title.includes('senate') && title.includes('democrat') && title.includes('house')) {
            markets.splitPct = pct;
          } else if (title.includes('democrat') && (title.includes('sweep') || title.includes('both'))) {
            markets.dSweepPct = pct;
          } else if (title.includes('republican') && (title.includes('sweep') || title.includes('both'))) {
            markets.repSweepPct = pct;
          }
        }
      }
    } catch (e) {
      console.error(`  Polymarket ${key} error:`, e.message);
    }
  }

  console.log('  Polymarket:', markets);
  return markets;
}

// ─── KALSHI ─────────────────────────────────────────────────────────────────

async function fetchKalshi() {
  console.log('Fetching Kalshi markets...');
  const markets = { houseD: null, senateR: null, splitPct: null, dSweepPct: null };

  try {
    // Kalshi public API v2
    const [houseRes, senateRes] = await Promise.allSettled([
      fetchJSON('https://api.elections.kalshi.com/v1/events/CONTROLH-2026'),
      fetchJSON('https://api.elections.kalshi.com/v1/events/CONTROLS-2026'),
    ]);

    if (houseRes.status === 'fulfilled') {
      const data = houseRes.value;
      const demMarket = data.markets?.find(m => m.subtitle?.toLowerCase().includes('democrat') || m.yes_sub_title?.toLowerCase().includes('democrat'));
      if (demMarket) markets.houseD = Math.round((demMarket.last_price || demMarket.yes_bid || 0));
    }

    if (senateRes.status === 'fulfilled') {
      const data = senateRes.value;
      const repMarket = data.markets?.find(m => m.subtitle?.toLowerCase().includes('republican') || m.yes_sub_title?.toLowerCase().includes('republican'));
      if (repMarket) markets.senateR = Math.round((repMarket.last_price || repMarket.yes_bid || 0));
    }
  } catch (e) {
    console.error('  Kalshi error:', e.message);
  }

  console.log('  Kalshi:', markets);
  return markets;
}

// ─── RCP GENERIC BALLOT ─────────────────────────────────────────────────────

async function fetchGenericBallot() {
  console.log('Fetching RCP generic ballot...');
  try {
    const html = await fetchHTML('https://www.realclearpolling.com/polls/congress/generic-congressional-ballot');
    const $ = cheerio.load(html);

    const polls = [];
    // RCP table rows
    $('table tr').each((i, row) => {
      if (i === 0) return; // skip header
      const cells = $(row).find('td');
      if (cells.length < 4) return;

      const source = $(cells[0]).text().trim();
      const date   = $(cells[1]).text().trim();
      const dem    = parseFloat($(cells[2]).text().trim());
      const rep    = parseFloat($(cells[3]).text().trim());

      if (!isNaN(dem) && !isNaN(rep) && source) {
        polls.push({ source, date, dem, rep, margin: (dem - rep).toFixed(1) });
      }
    });

    // Try to find RCP average row
    let avg = null;
    $('table tr').each((_, row) => {
      const text = $(row).text().toLowerCase();
      if (text.includes('rcp average') || text.includes('average')) {
        const cells = $(row).find('td');
        if (cells.length >= 4) {
          const dem = parseFloat($(cells[2]).text().trim());
          const rep = parseFloat($(cells[3]).text().trim());
          if (!isNaN(dem) && !isNaN(rep)) {
            avg = { dem, rep, margin: (dem - rep).toFixed(1) };
          }
        }
      }
    });

    console.log(`  Got ${polls.length} polls, avg: ${avg ? `D+${avg.margin}` : 'not found'}`);
    return { polls: polls.slice(0, 8), avg };
  } catch (e) {
    console.error('  RCP generic ballot error:', e.message);
    return { polls: [], avg: null };
  }
}

// ─── RCP SENATE RACE AVERAGES ────────────────────────────────────────────────

async function fetchSenatePolls() {
  console.log('Fetching RCP senate polls...');
  try {
    const html = await fetchHTML('https://www.realclearpolling.com/polls/senate');
    const $ = cheerio.load(html);

    const races = {};
    // Look for state race links and their averages
    $('a').each((_, el) => {
      const href = $(el).attr('href') || '';
      const text = $(el).text().trim();
      if (href.includes('/senate/') && text.length > 3) {
        // Extract state from link text
        const stateMatch = text.match(/^([A-Za-z\s]+)\s+Senate/i);
        if (stateMatch) {
          races[stateMatch[1].trim()] = href;
        }
      }
    });

    console.log(`  Found ${Object.keys(races).length} senate race links`);
    return races;
  } catch (e) {
    console.error('  RCP senate error:', e.message);
    return {};
  }
}

// ─── TRUMP APPROVAL (Silver Bulletin) ───────────────────────────────────────

async function fetchTrumpApproval() {
  console.log('Fetching Trump approval...');
  try {
    const html = await fetchHTML('https://www.realclearpolling.com/polls/approval/donald-trump/job-approval');
    const $ = cheerio.load(html);

    let approve = null, disapprove = null;

    // Look for RCP average row
    $('table tr').each((_, row) => {
      const text = $(row).text().toLowerCase();
      if (text.includes('rcp average') || text.includes('average')) {
        const cells = $(row).find('td');
        if (cells.length >= 3) {
          approve    = parseFloat($(cells[1]).text().trim()) || null;
          disapprove = parseFloat($(cells[2]).text().trim()) || null;
        }
      }
    });

    const net = (approve && disapprove) ? (approve - disapprove).toFixed(1) : null;
    console.log(`  Approval: ${approve}% approve, ${disapprove}% disapprove, net: ${net}`);
    return { approve, disapprove, net, source: 'RCP Average' };
  } catch (e) {
    console.error('  Trump approval error:', e.message);
    return { approve: null, disapprove: null, net: null };
  }
}

// ─── MAIN ────────────────────────────────────────────────────────────────────

async function main() {
  console.log(`\n=== Midterm Tracker Data Fetch — ${TODAY} ===\n`);

  const [ratings, polymarket, kalshi, genericBallot, trumpApproval] = await Promise.allSettled([
    fetchBallotpediaRatings(),
    fetchPolymarket(),
    fetchKalshi(),
    fetchGenericBallot(),
    fetchTrumpApproval(),
  ]);

  const todayEntry = {
    date: TODAY,
    fetchedAt: new Date().toISOString(),
    markets: {
      polymarket: polymarket.status === 'fulfilled' ? polymarket.value : {},
      kalshi:     kalshi.status === 'fulfilled'     ? kalshi.value     : {},
    },
    genericBallot: genericBallot.status === 'fulfilled' ? genericBallot.value : { polls: [], avg: null },
    senateRatings: ratings.status === 'fulfilled' ? ratings.value : {},
    trumpApproval: trumpApproval.status === 'fulfilled' ? trumpApproval.value : {},
  };

  // Ensure output directory exists
  mkdirSync('data', { recursive: true });

  // ── Append to history.json ──────────────────────────────────────────────
  let history = [];
  try {
    const raw = readFileSync('data/history.json', 'utf8');
    history = JSON.parse(raw);
  } catch {
    console.log('  No existing history.json — starting fresh');
  }

  // Replace today's entry if it already exists (re-run case), otherwise append
  const existingIdx = history.findIndex(e => e.date === TODAY);
  if (existingIdx >= 0) {
    history[existingIdx] = todayEntry;
    console.log(`  Replaced existing entry for ${TODAY}`);
  } else {
    history.push(todayEntry);
    console.log(`  Appended new entry for ${TODAY} (${history.length} total days)`);
  }

  writeFileSync('data/history.json', JSON.stringify(history, null, 2));

  // ── Also write data.json (latest snapshot for fast load) ────────────────
  const latest = {
    lastUpdated: TODAY,
    fetchedAt: todayEntry.fetchedAt,
    markets: todayEntry.markets,
    genericBallot: todayEntry.genericBallot,
    senateRatings: todayEntry.senateRatings,
    trumpApproval: todayEntry.trumpApproval,
  };
  writeFileSync('data/data.json', JSON.stringify(latest, null, 2));

  console.log('\n✅ data/data.json and data/history.json written successfully');
  console.log(`   History: ${history.length} days tracked`);
}

main().catch(err => {
  console.error('Fatal error:', err);
  process.exit(1);
});
